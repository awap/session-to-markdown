{
  "manifest_version": 3,
  "name": "Session to Markdown",
  "version": "0.1.0",
  "description": "ChatGPT, Claude, Gemini 대화 세션 전체를 이미지와 함께 Markdown 파일로 다운로드합니다.",
  "permissions": ["downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/serializer.js", "content/adapters.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Session to Markdown"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
